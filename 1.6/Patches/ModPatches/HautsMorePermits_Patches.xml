<?xml version="1.0" encoding="utf-8" ?>
<Patch>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Hauts' Enterprise: More Permits</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationFindMod">
					<mods>
						<li>Anomaly</li>
					</mods>
					<match Class="PatchOperationAddModExtension">
						<xpath>/Defs/GameConditionDef[defName="HVMP_LovecraftHypnoLight" or defName="HVMP_TOTU_BloodBlight" or defName="HVMP_TOTU_WeaknessOfFlesh"]</xpath>
						<value>
							<li Class="HautsTraits.CatastrophistLikedCondition" />
						</value>
					</match>
				</li>
				<li Class="PatchOperationFindMod">
					<mods>
						<li>Odyssey</li>
					</mods>
					<match Class="PatchOperationAddModExtension">
						<xpath>/Defs/GameConditionDef[defName="HVMP_OrbitalTargeting"]</xpath>
						<value>
							<li Class="HautsTraits.CatastrophistLikedCondition" />
						</value>
					</match>
				</li>
			</operations>
		</match>
	</Operation>
</Patch>